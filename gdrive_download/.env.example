# ===========================================
# CONTABILIDADE NOBEL - ARQUIVO DE EXEMPLO
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# ===========================================
# APIs DE INTELIGENCIA ARTIFICIAL (GRATUITAS)
# ===========================================

# Groq API - Modelo rapido e eficiente
# Obtenha em: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini 1.5 Flash
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# HuggingFace Inference API
# Obtenha em: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Cohere API (free tier)
# Obtenha em: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# ===========================================
# INTEGRACAO ALTERDATA (PREMIUM)
# ===========================================

# URL base da API Alterdata
ALTERDATA_URL=https://api.alterdata.com.br

# Token de autenticacao
ALTERDATA_TOKEN=

# ===========================================
# CONFIGURACOES DO SISTEMA
# ===========================================

# Nome da aplicacao
NEXT_PUBLIC_APP_NAME="Contabilidade Nobel"

# URL da aplicacao
NEXT_PUBLIC_APP_URL=http://localhost:3000
